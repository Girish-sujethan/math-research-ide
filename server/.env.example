# ─── LLM Providers ───────────────────────────────────────────────
# Supported values for *_PROVIDER: "claude" | "openai_compatible"
# "openai_compatible" covers OpenRouter, DeepSeek, Gemini, vLLM, etc.

PRIMARY_PROVIDER=openai_compatible
PRIMARY_MODEL=perplexity/sonar
CHEAP_PROVIDER=openai_compatible
CHEAP_MODEL=perplexity/sonar

# Anthropic (required if provider = "claude")
ANTHROPIC_API_KEY=

# OpenAI-compatible (required if provider = "openai_compatible")
# Base URLs:
#   OpenRouter: https://openrouter.ai/api/v1
#   DeepSeek:   https://api.deepseek.com/v1
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ─── External APIs ───────────────────────────────────────────────
WOLFRAM_APP_ID=
EXA_API_KEY=

# Perplexity (optional — used as web-grounded reasoning fallback)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# ─── Storage (defaults work out of the box) ──────────────────────
# SQLITE_URL=sqlite:///heaven.db
# CHROMA_PERSIST_DIR=chroma_data
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Lean 4 Verification (optional) ─────────────────────────────
# LEAN_EXECUTABLE=lean
# LEAN_PROJECT_DIR=lean_project
# LEAN_TIMEOUT_SECONDS=60

# ─── Rate Limiting & CORS ─────────────────────────────────────────
# Max requests per minute for the API (default: 30)
# RATE_LIMIT=30/minute

# Comma-separated allowed origins (default: * for development)
# Set to your frontend URL in production, e.g.:
# CORS_ORIGINS=https://heaven.yourdomain.com,http://localhost:3000
# CORS_ORIGINS=*
